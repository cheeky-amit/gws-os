#!/usr/bin/env bash
set -euo pipefail

# GWS OS Setup — idempotent one-time setup script
# Usage: bash setup [--add]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REGISTRY="$SCRIPT_DIR/accounts/registry.json"
PROFILES_DIR="$HOME/.config/gws-profiles"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}!${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1" >&2; }

# --- Check if already set up ---
if [[ -f "$REGISTRY" && "${1:-}" != "--add" ]]; then
    ACCOUNT_COUNT=$(jq '.accounts | length' "$REGISTRY")
    info "GWS OS already configured. $ACCOUNT_COUNT account(s) active."
    echo "  Run 'bash setup --add' to add an account."
    echo "  Run '/gws onboard' to reconfigure personas."
    exit 0
fi

# --- Check dependencies ---
echo "Checking dependencies..."

if ! command -v gws &>/dev/null; then
    error "gws CLI not found."
    echo "  Install: brew install googleworkspace-cli"
    echo "  Or see: https://github.com/googleworkspace/cli"
    exit 1
fi

GWS_VERSION=$(gws --version 2>&1 | head -1)
info "gws CLI found: $GWS_VERSION"

if ! command -v jq &>/dev/null; then
    error "jq not found."
    echo "  Install: brew install jq"
    exit 1
fi
info "jq found"

# --- Validate gws can reach Gmail API ---
echo ""
echo "Validating gws API access..."

if gws gmail users messages list --params '{"userId":"me","maxResults":1}' --format json &>/dev/null; then
    info "Gmail API access confirmed"
else
    error "Gmail API access failed. Run 'gws auth login' first."
    exit 1
fi

if gws calendar events list --params '{"calendarId":"primary","maxResults":1}' --format json &>/dev/null; then
    info "Calendar API access confirmed"
else
    warn "Calendar API access failed — calendar features may not work"
fi

# --- Create profile directories ---
mkdir -p "$PROFILES_DIR"

# --- Account setup ---
echo ""
echo "=== Account Setup ==="
echo "Configure a Google Workspace account."
echo ""

read -rp "Account ID (short name, e.g. 'business' or 'personal'): " ACCOUNT_ID
read -rp "Email address: " ACCOUNT_EMAIL
read -rp "Display label (e.g. 'Work' or 'Personal'): " ACCOUNT_LABEL
read -rp "Scan window (how far back to scan — 24h, 1w, 1m, 1y) [24h]: " SCAN_WINDOW
SCAN_WINDOW="${SCAN_WINDOW:-24h}"

read -rp "Is this the default account? (y/n) [y]: " IS_DEFAULT
IS_DEFAULT="${IS_DEFAULT:-y}"
[[ "$IS_DEFAULT" == "y" ]] && IS_DEFAULT_BOOL=true || IS_DEFAULT_BOOL=false

# --- Create profile config dir ---
PROFILE_DIR="$PROFILES_DIR/$ACCOUNT_ID"
mkdir -p "$PROFILE_DIR"

# Check if profile needs auth
if [[ ! -f "$PROFILE_DIR/credentials.enc" && ! -f "$PROFILE_DIR/token_cache.json" ]]; then
    warn "Profile '$ACCOUNT_ID' needs authentication."
    echo "  Run: GOOGLE_WORKSPACE_CLI_CONFIG_DIR=$PROFILE_DIR gws auth login"
    echo "  Then re-run this setup."
    echo ""
    echo "  If this is your default gws account, you can copy existing credentials:"
    echo "  cp -r ~/.config/gws/* $PROFILE_DIR/"
fi

# --- Write/update registry ---
if [[ -f "$REGISTRY" ]]; then
    # Add account to existing registry
    UPDATED=$(jq --arg id "$ACCOUNT_ID" \
                  --arg email "$ACCOUNT_EMAIL" \
                  --arg label "$ACCOUNT_LABEL" \
                  --arg window "$SCAN_WINDOW" \
                  --argjson default "$IS_DEFAULT_BOOL" \
    '.accounts += [{
        "id": $id,
        "email": $email,
        "label": $label,
        "persona": ("personas/" + $id + ".md"),
        "gws_profile": $id,
        "is_default": $default,
        "scan_window": $window
    }]' "$REGISTRY")
    echo "$UPDATED" > "$REGISTRY"
else
    # Create new registry
    cat > "$REGISTRY" <<EOF
{
  "accounts": [
    {
      "id": "$ACCOUNT_ID",
      "email": "$ACCOUNT_EMAIL",
      "label": "$ACCOUNT_LABEL",
      "persona": "personas/${ACCOUNT_ID}.md",
      "gws_profile": "$ACCOUNT_ID",
      "is_default": $IS_DEFAULT_BOOL,
      "scan_window": "$SCAN_WINDOW"
    }
  ],
  "default_account": "$ACCOUNT_ID"
}
EOF
fi

info "Account '$ACCOUNT_ID' ($ACCOUNT_EMAIL) added to registry"

# --- Initialize memory directories ---
mkdir -p "$SCRIPT_DIR/memory/contacts" "$SCRIPT_DIR/memory/topics" "$SCRIPT_DIR/memory/actions"

# Seed trust-levels.json if not exists
if [[ ! -f "$SCRIPT_DIR/memory/trust-levels.json" ]]; then
    cat > "$SCRIPT_DIR/memory/trust-levels.json" <<'EOF'
{
  "_comment": "Global defaults — template for new contacts only. Contact nodes override these once created.",
  "defaults": {
    "reply": "observe",
    "archive": "observe",
    "schedule": "observe",
    "followup": "observe",
    "search": "suggest"
  },
  "promotion_thresholds": {
    "observe_to_suggest": 5,
    "suggest_to_assist": 3,
    "assist_to_automate": 5
  }
}
EOF
    info "Trust levels template seeded"
fi

# --- Create example persona if not exists ---
if [[ ! -f "$SCRIPT_DIR/accounts/personas/${ACCOUNT_ID}.md" ]]; then
    cat > "$SCRIPT_DIR/accounts/personas/${ACCOUNT_ID}.md" <<EOF
# Persona: $ACCOUNT_LABEL ($ACCOUNT_EMAIL)

## Identity
- Tone: professional
- Sign-off: "Best, [Name]"
- Response time: same business day

## Priorities
1. Client emails
2. Operations issues
3. Team coordination
4. Everything else

## VIP Contacts
- (add VIP contacts here, or use /gws onboard)

## Rules
- Never auto-archive client emails
- Schedule follow-ups for action-required emails

## Calendar
- Business hours: 09:00-18:00
- No meetings before 10:00
- Friday: half day
EOF
    info "Persona template created: accounts/personas/${ACCOUNT_ID}.md"
fi

# --- Summary ---
ACCOUNT_COUNT=$(jq '.accounts | length' "$REGISTRY")
echo ""
info "GWS OS setup complete. $ACCOUNT_COUNT account(s) configured."
echo ""
echo "Next steps:"
echo "  1. Run '/gws onboard' to configure personas and SOPs"
echo "  2. Run '/gws triage' to start triaging email"
